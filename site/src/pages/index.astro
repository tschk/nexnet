---
import Base from "../layouts/Base.astro";
import Scramble from "../components/Scramble.astro";
---

<Base>
  <main class="wrap page">
    <p class="muted line">
      <a href="/">nexnet</a>
      <span class="sep">·</span>
      <a href="https://github.com/tschk/nexnet">github</a>
    </p>

    <h1>
      <Scramble text="nexnet" as="span" speed={20} delay={100} inView={false} />
    </h1>

    <p class="lede">
      <Scramble
        text="p2p social chat"
        as="span"
        speed={20}
        delay={400}
        inView={false}
      />
    </p>

    <p class="muted body">
      Blockchain identity. Local-first history. E2EE DMs and groups. Public
      rooms. No telemetry.
    </p>

    <ul class="list muted">
      <li>double ratchet · x3dh · mls</li>
      <li>webrtc direct · relay fallback</li>
      <li>open source · isc</li>
    </ul>

    <p class="line">
      <a href="https://github.com/tschk/nexnet">clone on github →</a>
    </p>

    <p class="muted foot">
      presence.nexnet.tsc.hk · relay.nexnet.tsc.hk · discovery.nexnet.tsc.hk
    </p>
  </main>
</Base>

<style>
  .page {
    padding: 20vh 0 4rem;
  }

  .line {
    margin: 0 0 2.5rem;
    font-size: 12px;
    letter-spacing: 0.04em;
  }

  .line a {
    text-decoration: none;
  }

  .sep {
    margin: 0 0.5rem;
    color: var(--muted);
  }

  h1 {
    margin: 0;
    font-size: clamp(2.5rem, 10vw, 4rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .lede {
    margin: 1rem 0 0;
    font-size: 1.1rem;
    font-weight: 400;
  }

  .body {
    margin: 1.5rem 0 0;
    max-width: 28rem;
  }

  .list {
    margin: 2rem 0;
    padding: 0;
    list-style: none;
  }

  .list li {
    margin: 0.25rem 0;
  }

  .list li::before {
    content: "› ";
    color: var(--muted);
  }

  .foot {
    margin-top: 4rem;
    font-size: 11px;
    letter-spacing: 0.02em;
    word-break: break-all;
  }
</style>
