---
interface Props {
  title?: string;
  class?: string;
}
const { title = "nexnet@tsc.hk:~", class: className = "" } = Astro.props;
---

<section class:list={["term", className]}>
  <header class="term__bar">
    <span class="term__dots" aria-hidden="true">
      <i></i><i></i><i></i>
    </span>
    <span class="term__title">{title}</span>
    <span class="term__meta dim">utf-8</span>
  </header>
  <div class="term__body">
    <slot />
  </div>
</section>

<style>
  .term {
    border: 1px solid var(--line);
    background: #050505;
  }

  .term__bar {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    align-items: center;
    padding: 0.55rem 0.85rem;
    border-bottom: 1px solid var(--line);
    font-size: 12px;
    color: var(--muted);
  }

  .term__dots {
    display: flex;
    gap: 0.35rem;
  }

  .term__dots i {
    width: 0.5rem;
    height: 0.5rem;
    border: 1px solid var(--dim);
    border-radius: 50%;
    display: block;
  }

  .term__title {
    text-align: center;
    letter-spacing: 0.08em;
    text-transform: lowercase;
  }

  .term__body {
    padding: clamp(1rem, 2.5vw, 1.75rem);
  }
</style>
